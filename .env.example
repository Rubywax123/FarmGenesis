# PostgreSQL connection string used by Prisma (the only required secret).
# Locally: copy this file to .env and fill in real credentials.
# In production: set via Replit Secrets — never commit a real .env.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=disable"

# PORT is optional. Replit sets it automatically in deployments;
# the server falls back to 3000 locally.
# PORT=3000
