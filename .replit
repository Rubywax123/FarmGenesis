modules = ["nodejs-24"]

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "pnpm build"]
run = ["sh", "-c", "npx prisma migrate deploy && pnpm start"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"

[[ports]]
localPort = 3000
externalPort = 80

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
