{
  "name": "farmforecast",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');for(const f of['package-lock.json','yarn.lock'])fs.rmSync(f,{force:true});if(!/^pnpm\\//.test(process.env.npm_config_user_agent||'')){console.error('Use pnpm instead');process.exit(1)}\"",
    "dev": "next dev",
    "build": "pnpm run typecheck:engine && pnpm run typecheck:app && next build",
    "start": "next start -H 0.0.0.0",
    "start:prod": "prisma migrate deploy && next start -H 0.0.0.0",
    "seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "typecheck:engine": "tsc -p tsconfig.engine.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm run typecheck:engine && pnpm run typecheck:app",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^15.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-is": "^19.2.7",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.3",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.9.5",
    "prisma": "^6.16.2",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.5",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
